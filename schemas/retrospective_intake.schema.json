{
  "schema_version": "0.1.0",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "run_id",
    "do_not_promote_without_human_approval",
    "retrospective_collection_plan",
    "domain_question_bank",
    "run_local_candidates",
    "run_local_approval_summary",
    "run_local_blocked_candidate_repair_plan",
    "run_local_repair_priority_queue",
    "run_local_ready_candidate_commands",
    "knowledge_growth_priority"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "do_not_promote_without_human_approval": {
      "type": "boolean",
      "const": true
    },
    "retrospective_collection_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "domain",
          "needed_entries",
          "suggested_target_artifacts",
          "candidate_commands"
        ]
      }
    },
    "domain_question_bank": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "domain",
          "label",
          "requirement_id",
          "gap_id",
          "needed_entries",
          "min_status",
          "questions",
          "suggested_target_artifacts"
        ],
        "properties": {
          "domain": {
            "type": "string",
            "enum": [
              "bazi",
              "ziwei",
              "western",
              "liuyao",
              "writing",
              "relationship",
              "team_career",
              "fengshui",
              "*"
            ]
          },
          "label": {
            "type": "string"
          },
          "requirement_id": {
            "type": "string"
          },
          "gap_id": {
            "type": "string"
          },
          "needed_entries": {
            "type": "integer",
            "minimum": 1
          },
          "min_status": {
            "type": "string",
            "enum": [
              "candidate",
              "curated",
              "verified"
            ]
          },
          "questions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "suggested_target_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      }
    },
    "run_local_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file",
          "id",
          "status",
          "domains",
          "human_approved",
          "target_artifacts",
          "approval_ready",
          "approval_blockers",
          "domain_evidence_required",
          "matched_unsatisfied_requirements_after_repair",
          "repair_priority_score",
          "repair_priority_reason",
          "promotion_dry_run_command",
          "promotion_command"
        ]
      }
    },
    "run_local_approval_summary": {
      "type": "object",
      "required": [
        "candidate_count",
        "ready_for_human_approval",
        "needs_fix_before_approval",
        "already_human_approved",
        "ready_candidate_ids",
        "blocked_candidate_ids"
      ]
    },
    "run_local_blocked_candidate_repair_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "candidate_path",
          "approval_blockers",
          "repair_actions",
          "domain_evidence_templates",
          "matched_unsatisfied_requirements_after_repair",
          "repair_priority_score",
          "repair_priority_reason",
          "recheck_command",
          "promotion_dry_run_command_after_fix"
        ]
      }
    },
    "run_local_repair_priority_queue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "candidate_path",
          "approval_blockers",
          "repair_actions",
          "domain_evidence_templates",
          "matched_unsatisfied_requirements_after_repair",
          "repair_priority_score",
          "repair_priority_reason",
          "recheck_command",
          "promotion_dry_run_command_after_fix"
        ]
      }
    },
    "run_local_ready_candidate_commands": {
      "type": "object",
      "required": [
        "dry_run",
        "promote",
        "post_promotion_audits"
      ]
    },
    "knowledge_growth_priority": {
      "type": "object",
      "required": [
        "prefer",
        "avoid",
        "decision_labels"
      ]
    }
  }
}
